{
	"name": "ingestion-lambda",
	"version": "1.0.0",
	"description": "",
	"scripts": {
		"local": "STAGE=dev tsx watch localRun.ts",
		"typecheck": "tsc -noEmit",
		"build": "esbuild src/handler.ts --bundle --minify --outfile=dist/handler.js --external:@aws-sdk --external:aws-sdk --platform=node",
